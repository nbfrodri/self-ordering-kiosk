# Version control
.git
.gitignore
.gitattributes

# Composer and Node dependencies (installed inside the container)
vendor/
node_modules/

# Frontend build artifacts
public/hot
public/build/

# Laravel runtime files
storage/logs/*.log
storage/framework/cache/
storage/framework/sessions/
storage/framework/views/
bootstrap/cache/*.php

# Environment files — never bake secrets into an image
.env
.env.*
!.env.example

# Docker configuration (not needed inside the image)
docker/
docker-compose.yml
docker-compose.*.yml

# IDE and editor files
.idea/
.vscode/
*.iml
*.swp
*.swo
.DS_Store
Thumbs.db

# Test and CI artifacts
.phpunit.cache/
coverage/

# Documentation
*.md
LICENSE
